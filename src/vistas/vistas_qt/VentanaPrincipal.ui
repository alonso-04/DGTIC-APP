   <string notr="true">
#ventanaPrincipal {
	background-color: qlineargradient(spread:reflect, x1:0, y1:0, x2:1, y2:1, stop:0.477612 rgba(72, 111, 182, 255), stop:0.751244 rgba(31, 72, 133, 255))
}


/* BOTÓN DE MANUAL DE USUARIO  */

#botonManualUsuarioSeccionIniciarSesion,
#frameSuperior #botonManualUsuarioSeccionApp,
#frameSeccionRegistrarDepartamento #botonManualUsuarioSeccionDepartamentos,
#frameSeccionRegistrarUsuario #botonManualUsuarioSeccionUsuarios,
#frameSuperiorTipoServicio #botonManualUsuarioSeccionTipoServicio,
#frameSuperiorCategoriaTipoServicio #botonManualUsuarioSeccionCategoriaTipoServicio {
	background-image: url(:/iconos/iconos/help.png);
	background-repeat: no-repeat;
	background-position: center;
	background-color: #fff;
	border: 1px solid #000000;
	border-radius: 15px;
}


#botonManualUsuarioSeccionIniciarSesion::hover,
#frameSuperior #botonManualUsuarioSeccionApp::hover,
#frameSeccionRegistrarDepartamento #botonManualUsuarioSeccionDepartamentos::hover,
#frameSeccionRegistrarUsuario #botonManualUsuarioSeccionUsuarios::hover,
#frameSuperiorTipoServicio #botonManualUsuarioSeccionTipoServicio::hover,
#frameSuperiorCategoriaTipoServicio #botonManualUsuarioSeccionCategoriaTipoServicio::hover {
	background-color: #dadada;
}


#botonManualUsuarioSeccionIniciarSesion::pressed,
#frameSuperior #botonManualUsuarioSeccionApp::pressed,
#frameSeccionRegistrarDepartamento #botonManualUsuarioSeccionDepartamentos::pressed,
#frameSeccionRegistrarUsuario #botonManualUsuarioSeccionUsuarios::pressed,
#frameSuperiorTipoServicio #botonManualUsuarioSeccionTipoServicio::pressed {
	background-color: #a3a3a3;
}


/* PÁGINA DE INICIAR SESIÓN */

#frameCamposInicioSesion {
	background-color: rgb(229, 229, 229);
	border-radius: 10px;
}

#labelTituloIniciarSesion {
	font-size: 30px;
	font-weight: bold;
}

#labelNombreUsuario,
#labelClaveUsuario {
	font-size: 17px;
	font-weight: bold;
}

QWidget{
	font: 10pt &quot;Arial&quot;;
}

#botonAcceder{
	font: 10pt &quot;Arial&quot;;
	color: #ffffff;
	background-color: #115ad3;
	border: 2px solid rgb(0, 0, 0);
	border-radius: 10px;
	padding-bottom: 2px;
}

#botonAcceder::hover{
	background-color: #5c8bc9;
}

#botonAcceder::pressed{
	background-color: #063c85;
}



/* PÁGINA APP*/

#frameApp{
	background-color: rgb(255, 255, 255);
	border: 1px solid #000000;
	border-radius: 4px;
}

#frameInferior .QPushButton{
	color: #ffffff;
	background-color: #417fd2;
	border: 1px solid rgb(0, 0, 0);
	border-radius: 10px;
	padding-bottom: 2px;
	font: 10pt &quot;Arial&quot;;
}

#frameInferior .QPushButton::hover{
	background-color: #5c8bc9;
}

#frameInferior .QPushButton::pressed{
	background-color: #063c85;
}

#frameSuperior .QToolButton{
	color: #ffffff;
	background-color: #417fd2;
	border: 1px solid rgb(0, 0, 0);
	border-radius: 10px;
	padding-bottom: 2px;
	font: 9pt &quot;Segoe UI&quot;;
}

#frameSuperior .QToolButton::hover{
	background-color: #5c8bc9;
}

#frameSuperior .QToolButton::pressed{
	background-color: #063c85;
}


#frameSuperior .QPushButton{
	color: #ffffff;
	background-color: #417fd2;
	border: 1px solid rgb(0, 0, 0);
	border-radius: 10px;
	padding-bottom: 2px;
	font: 10pt &quot;Arial&quot;;
}

#frameSuperior .QPushButton::hover{
	background-color: #5c8bc9;
}

#frameSuperior .QPushButton::pressed{
	background-color: #063c85;
}

#frameSuperior #botonRefrescarApp{
	background-color: #c8c8c8;
}


#frameSuperior #botonRefrescarApp::hover{
	background-color: #dadada;
}

#frameSuperior #botonRefrescarApp::pressed{
	background-color: #a3a3a3;
}



/* PÁGINA DEPARTAMENTOS*/

#frameGeneralDepartamentos{
	background-color: rgb(255, 255, 255);
	border: 1px solid #000000;
	border-radius: 4px;
}

#frameSeccionRegistrarDepartamento .QPushButton,
#frameInferiorSeccionDepartamentos .QPushButton {
	color: #ffffff;
	background-color: #417fd2;
	border: 1px solid rgb(0, 0, 0);
	border-radius: 6px;
	padding-bottom: 2px;
	font: 10pt &quot;Arial&quot;;
}

#frameSeccionRegistrarDepartamento .QPushButton::hover,
#frameInferiorSeccionDepartamentos .QPushButton::hover{
	background-color: #5c8bc9;
}

#frameSeccionRegistrarDepartamento .QPushButton::pressed,
#frameInferiorSeccionDepartamentos .QPushButton::pressed{
	background-color: #063c85;
}

#labelTituloRegistrarDepartamento {
	font-weight: bold;
	font-size: 20px;
}

#frameSeccionRegistrarDepartamento #botonRefrescarDepartamentos{
	background-color: #c8c8c8;
}

#frameSeccionRegistrarDepartamento #botonRefrescarDepartamentos::hover{
	background-color: #dadada;
}

#frameSeccionRegistrarDepartamento #botonRefrescarDepartamentos::pressed{
	background-color: #a3a3a3;
}



